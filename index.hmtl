<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3D MODEL BETUNG - AUTO LOAD</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script src="https://unpkg.com/fflate"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/FBXLoader.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { margin: 0; overflow: hidden; background: #000; font-family: 'Inter', sans-serif; }
        canvas { display: block; }
        .ui-chrome {
            background: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent);
            pointer-events: none;
        }
        .glass-card {
            background: rgba(10, 10, 10, 0.6);
            backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            pointer-events: auto;
        }
    </style>
</head>
<body>

    <div class="absolute inset-0 ui-chrome z-10 p-8 flex flex-col justify-between">
        <div class="flex justify-between items-start">
            <div class="glass-card p-5 rounded-2xl shadow-2xl">
                <h1 class="text-2xl font-black text-white tracking-tighter italic">3D MODEL BETUNG</h1>
                <div class="flex items-center gap-2 mt-1">
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.3em]">Live Renderer • Auto-Loaded</p>
                </div>
            </div>
        </div>

        <div class="flex justify-center mb-4">
            <div class="glass-card px-8 py-4 rounded-full flex gap-10 items-center border-white/10 shadow-[0_0_50px_rgba(0,0,0,0.5)]">
                <div class="text-center"><p class="text-[10px] text-white/40 uppercase font-black">Lighting</p><p class="text-xs text-white font-bold">Physical</p></div>
                <div class="w-px h-8 bg-white/10"></div>
                <div class="text-center"><p class="text-[10px] text-white/40 uppercase font-black">Shadows</p><p class="text-xs text-white font-bold">PCF Soft</p></div>
                <div class="w-px h-8 bg-white/10"></div>
                <div class="text-center"><p class="text-[10px] text-white/40 uppercase font-black">Material</p><p class="text-xs text-white font-bold">Metallic-Rough</p></div>
            </div>
        </div>
    </div>

    <div id="loader" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-black transition-opacity duration-1000">
        <div class="text-white font-black italic text-4xl mb-4 animate-pulse">INITIALIZING...</div>
        <div class="w-64 h-1 bg-white/10 rounded-full overflow-hidden">
            <div id="progress-bar" class="w-0 h-full bg-blue-600 transition-all duration-300"></div>
        </div>
        <p id="status-text" class="text-slate-500 text-xs mt-4 tracking-widest uppercase">Loading 3D Assets</p>
    </div>

    <script>
        let scene, camera, renderer, controls;
        let isInitialized = false;

        // GANTI INI DENGAN NAMA FILE FBX ANDA
        const MODEL_URL = 'nama_file_anda.fbx'; 

        async function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x050505);
            
            camera = new THREE.PerspectiveCamera(35, window.innerWidth / window.innerHeight, 0.1, 10000);
            camera.position.set(300, 200, 500);

            renderer = new THREE.WebGLRenderer({ 
                antialias: true, 
                powerPreference: "high-performance",
                logarithmicDepthBuffer: true
            });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            
            renderer.outputEncoding = THREE.sRGBEncoding;
            renderer.toneMapping = THREE.ACESFilmicToneMapping;
            renderer.toneMappingExposure = 1.2;
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            
            document.body.appendChild(renderer.domElement);

            // Lighting
            const hemiLight = new THREE.HemisphereLight(0xffffff, 0x444444, 0.6);
            scene.add(hemiLight);

            const sunLight = new THREE.DirectionalLight(0xffffff, 3.0);
            sunLight.position.set(100, 250, 150);
            sunLight.castShadow = true;
            sunLight.shadow.mapSize.set(2048, 2048);
            scene.add(sunLight);

            // Ground
            const ground = new THREE.Mesh(
                new THREE.PlaneGeometry(10000, 10000),
                new THREE.MeshStandardMaterial({ color: 0x111111, roughness: 0.2, metalness: 0.8 })
            );
            ground.rotation.x = -Math.PI / 2;
            ground.receiveShadow = true;
            scene.add(ground);

            // Controls
            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.autoRotate = true;

            window.addEventListener('resize', onWindowResize);
            
            // Start loading the model automatically
            loadModel(MODEL_URL);
            
            isInitialized = true;
            animate();
        }

        function loadModel(url) {
            const loader = new THREE.FBXLoader();
            const loaderEl = document.getElementById('loader');
            const progress = document.getElementById('progress-bar');
            const statusText = document.getElementById('status-text');

            loader.load(url, (object) => {
                const box = new THREE.Box3().setFromObject(object);
                const size = box.getSize(new THREE.Vector3());
                const center = box.getCenter(new THREE.Vector3());
                
                // Auto Scaling
                const maxDim = Math.max(size.x, size.y, size.z);
                const scale = 200 / maxDim;
                object.scale.setScalar(scale);
                
                // Center and position on floor
                object.position.sub(center.multiplyScalar(scale));
                object.position.y = 0;

                object.traverse((node) => {
                    if (node.isMesh) {
                        node.castShadow = true;
                        node.receiveShadow = true;
                        if (node.material) {
                            const materials = Array.isArray(node.material) ? node.material : [node.material];
                            materials.forEach(m => {
                                m.roughness = Math.min(m.roughness || 0.4, 0.5);
                                m.metalness = Math.max(m.metalness || 0.5, 0.3);
                                m.envMapIntensity = 1.2;
                            });
                        }
                    }
                });

                scene.add(object);
                
                // Hide loader
                loaderEl.style.opacity = '0';
                setTimeout(() => loaderEl.style.display = 'none', 1000);

            }, (xhr) => {
                const percent = (xhr.loaded / xhr.total * 100);
                progress.style.width = percent + '%';
                statusText.innerText = `FETCHING DATA: ${Math.round(percent)}%`;
            }, (error) => {
                console.error(error);
                statusText.innerText = "Gagal memuat model. Pastikan file ada.";
                statusText.style.color = "#ff4444";
            });
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);
            if (controls) controls.update();
            if (renderer && scene && camera) renderer.render(scene, camera);
        }

        init();
    </script>
</body>
</html>
