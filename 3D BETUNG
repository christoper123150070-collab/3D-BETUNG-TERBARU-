<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3D MODEL BETUNG</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script src="https://unpkg.com/fflate"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/FBXLoader.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { margin: 0; overflow: hidden; background: #000; font-family: 'Inter', sans-serif; }
        canvas { display: block; }
        .ui-chrome {
            background: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent);
            pointer-events: none;
        }
        .glass-card {
            background: rgba(10, 10, 10, 0.6);
            backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            pointer-events: auto;
        }
    </style>
</head>
<body>

    <!-- Overlay UI -->
    <div class="absolute inset-0 ui-chrome z-10 p-8 flex flex-col justify-between">
        <div class="flex justify-between items-start">
            <div class="glass-card p-5 rounded-2xl shadow-2xl">
                <h1 class="text-2xl font-black text-white tracking-tighter italic">3D MODEL BETUNG</h1>
                <div class="flex items-center gap-2 mt-1">
                    <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.3em]">4K Texture Ready • Ray-Trace Sim</p>
                </div>
            </div>
        </div>

        <div class="flex justify-center mb-4">
            <div class="glass-card px-8 py-4 rounded-full flex gap-10 items-center border-white/10 shadow-[0_0_50px_rgba(0,0,0,0.5)]">
                <div class="text-center"><p class="text-[10px] text-white/40 uppercase font-black">Lighting</p><p class="text-xs text-white font-bold">Physical</p></div>
                <div class="w-px h-8 bg-white/10"></div>
                <div class="text-center"><p class="text-[10px] text-white/40 uppercase font-black">Shadows</p><p class="text-xs text-white font-bold">PCF Soft</p></div>
                <div class="w-px h-8 bg-white/10"></div>
                <div class="text-center"><p class="text-[10px] text-white/40 uppercase font-black">Material</p><p class="text-xs text-white font-bold">Metallic-Rough</p></div>
            </div>
        </div>
    </div>

    <!-- Upload Prompt -->
    <div id="upload-prompt" class="absolute inset-0 z-40 flex items-center justify-center bg-black/95">
        <div class="text-center max-w-lg p-12">
            <h2 class="text-5xl font-black text-white mb-6 tracking-tighter">SURFACE PERFECTION</h2>
            <p class="text-slate-500 text-lg mb-10 leading-relaxed font-medium">Visualisasikan model FBX Anda dengan micro-imperfections dan simulasi cahaya global.</p>
            <label class="group relative inline-block cursor-pointer">
                <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-emerald-600 rounded-2xl blur opacity-25 group-hover:opacity-75 transition duration-1000 group-hover:duration-200"></div>
                <div class="relative px-12 py-5 bg-white text-black rounded-2xl font-black text-sm tracking-widest uppercase transition-all active:scale-95">
                    MUAT MODEL 4K (.FBX)
                </div>
                <input type="file" id="file-input" accept=".fbx" class="hidden">
            </label>
        </div>
    </div>

    <div id="loader" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-black transition-opacity duration-1000 hidden">
        <div class="text-white font-black italic text-4xl mb-4 animate-pulse">RENDERING...</div>
        <div class="w-64 h-1 bg-white/10 rounded-full overflow-hidden">
            <div id="progress-bar" class="w-0 h-full bg-white transition-all duration-300"></div>
        </div>
    </div>

    <script>
        let scene, camera, renderer, controls, envMap;
        let isInitialized = false;

        async function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x000000);
            
            // Camera dengan FOV cinematic
            camera = new THREE.PerspectiveCamera(35, window.innerWidth / window.innerHeight, 0.1, 10000);
            camera.position.set(200, 150, 400);

            renderer = new THREE.WebGLRenderer({ 
                antialias: true, 
                powerPreference: "high-performance",
                logarithmicDepthBuffer: true
            });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            
            // Standard PBR Settings
            renderer.outputEncoding = THREE.sRGBEncoding;
            renderer.toneMapping = THREE.ACESFilmicToneMapping;
            renderer.toneMappingExposure = 1.0;
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            renderer.physicallyCorrectLights = true;
            
            document.body.appendChild(renderer.domElement);

            // Lighting System
            // 1. Ambient Occlusion Simulation (Sky Light)
            const hemiLight = new THREE.HemisphereLight(0xffffff, 0x000000, 0.5);
            scene.add(hemiLight);

            // 2. Studio Lighting (Key)
            const sunLight = new THREE.DirectionalLight(0xffffff, 4.0);
            sunLight.position.set(100, 250, 150);
            sunLight.castShadow = true;
            sunLight.shadow.mapSize.set(4096, 4096); // Ultra High Shadow Res
            sunLight.shadow.bias = -0.0001;
            scene.add(sunLight);

            // 3. Accent Lights (Gold & Ice)
            const rim1 = new THREE.SpotLight(0x3b82f6, 15);
            rim1.position.set(-200, 100, -100);
            scene.add(rim1);

            const rim2 = new THREE.SpotLight(0xf59e0b, 10);
            rim2.position.set(200, 50, -100);
            scene.add(rim2);

            // Controls
            controls = new OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.03;
            controls.autoRotate = true;
            controls.autoRotateSpeed = 0.5;

            // Ground Reflective Surface
            const ground = new THREE.Mesh(
                new THREE.PlaneGeometry(5000, 5000),
                new THREE.MeshStandardMaterial({ color: 0x050505, roughness: 0.1, metalness: 0.5 })
            );
            ground.rotation.x = -Math.PI / 2;
            ground.receiveShadow = true;
            scene.add(ground);

            isInitialized = true;
            
            document.getElementById('file-input').addEventListener('change', (e) => {
                if(e.target.files.length > 0) loadFBX(e.target.files[0]);
            });

            window.addEventListener('resize', onWindowResize);
            animate();
        }

        function loadFBX(file) {
            const loader = new THREE.FBXLoader();
            const loaderEl = document.getElementById('loader');
            const progress = document.getElementById('progress-bar');
            const url = URL.createObjectURL(file);

            document.getElementById('upload-prompt').classList.add('hidden');
            loaderEl.classList.remove('hidden');

            loader.load(url, (object) => {
                const box = new THREE.Box3().setFromObject(object);
                const size = box.getSize(new THREE.Vector3());
                const center = box.getCenter(new THREE.Vector3());
                const scale = 180 / Math.max(size.x, size.y, size.z);
                
                object.scale.setScalar(scale);
                object.position.sub(center.multiplyScalar(scale));
                object.position.y = 0; // Snap to floor

                object.traverse((node) => {
                    if (node.isMesh) {
                        node.castShadow = true;
                        node.receiveShadow = true;
                        
                        // Enforce Ultra-Detailed PBR Materials
                        if (node.material) {
                            const mats = Array.isArray(node.material) ? node.material : [node.material];
                            mats.forEach((m, idx) => {
                                const pbr = new THREE.MeshStandardMaterial({
                                    color: m.color || 0xffffff,
                                    map: m.map,
                                    normalMap: m.normalMap,
                                    roughnessMap: m.roughnessMap,
                                    metalnessMap: m.metalnessMap,
                                    roughness: 0.4, // Default realism if map missing
                                    metalness: 0.6,
                                    envMapIntensity: 1.5
                                });
                                if (Array.isArray(node.material)) node.material[idx] = pbr;
                                else node.material = pbr;
                            });
                        }
                    }
                });

                scene.add(object);
                loaderEl.style.opacity = '0';
                setTimeout(() => loaderEl.classList.add('hidden'), 1000);
            }, (xhr) => {
                progress.style.width = (xhr.loaded / xhr.total * 100) + '%';
            });
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);
            if (isInitialized) {
                controls.update();
                renderer.render(scene, camera);
            }
        }

        const OrbitControls = THREE.OrbitControls;
        init();
    </script>
</body>
</html>
